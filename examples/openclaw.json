{
  "plugins": {
    "load": {
      "paths": [
        "~/hybrid-memq/plugin/openclaw-memory-memq"
      ]
    },
    "slots": {
      "memory": "openclaw-memory-memq"
    }
  },
  "memq": {
    "workspaceRoot": "~/hybrid-memq",
    "sidecarUrl": "http://127.0.0.1:7781",
    "mode": "api_text",
    "budgetTokens": 120,
    "topK": 5,
    "retrieval": {
      "topM": 12
    },
    "surface": {
      "max": 120,
      "ttlSec": 172800
    },
    "writeGate": {
      "low": 0.45,
      "high": 0.65
    },
    "fallback": {
      "maxScoreMin": 0.32,
      "entropyMax": 1.2
    },
    "consolidation": {
      "intervalSec": 3600
    },
    "history": {
      "reconstruct": {
        "enabled": true
      },
      "hardCap": {
        "enabled": true
      },
      "keepRecentMessages": 6,
      "keepStrategy": "importance_recency",
      "summarizeMinMessages": 8,
      "archivePruned": {
        "enabled": true,
        "redactSecrets": {
          "enabled": true
        },
        "maxFileBytes": 5242880,
        "maxFiles": 20,
        "retentionDays": 14
      }
    },
    "compat": {
      "enableLegacyBeforeAgentStart": false
    }
  }
}
